# VM2 env (yt-service + downloads + internal HTTP)
COMPOSE_PROJECT_NAME=yt-hub-vm2
VERSION=latest

LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
MAX_MESSAGE_SIZE=4194304
DOWNLOAD_DIR=./downloads

INTERNAL_HTTP_HOST=0.0.0.0
INTERNAL_HTTP_PORT=8081
INTERNAL_API_KEY=replace-with-strong-shared-secret

# Optional: host port bindings in docker-compose.prod.vm2.yml
VM2_GRPC_BIND=50051
VM2_INTERNAL_HTTP_BIND=8081
