# yt-service configuration
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
MAX_MESSAGE_SIZE=4194304
# From packages/yt-service: same repo-root folder as yt-api when FILE_DELIVERY_MODE=local.
DOWNLOAD_DIR=../../downloads
INTERNAL_HTTP_HOST=0.0.0.0
INTERNAL_HTTP_PORT=8081
# Match yt-api. When local, INTERNAL_API_KEY is not required and internal HTTP only exposes /internal/health.
FILE_DELIVERY_MODE=local
# Required when FILE_DELIVERY_MODE=remote (min 16 characters).
# INTERNAL_API_KEY=
