# yt-api configuration
YT_API_HOST=0.0.0.0
YT_API_PORT=3000
GRPC_TARGET=http://localhost:50051
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
STREAMING_TIMEOUT_SECS=600
MAX_BODY_SIZE_BYTES=1048576
RATE_LIMIT_RPM=30
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# From packages/yt-api: repo-root downloads/ (create with `mkdir -p ../../downloads` or run `npm run dev`).
DOWNLOAD_DIR=../../downloads

# File delivery mode:
# - local: yt-api serves files from DOWNLOAD_DIR
# - remote: yt-api proxies file stream from yt-service internal HTTP endpoint
FILE_DELIVERY_MODE=local

# Required only when FILE_DELIVERY_MODE=remote
INTERNAL_FILE_BASE_URL=http://localhost:8081
INTERNAL_API_KEY=change-me
