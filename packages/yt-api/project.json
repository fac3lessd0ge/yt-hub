{
  "name": "yt-api",
  "projectType": "application",
  "sourceRoot": "packages/yt-api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --release",
        "cwd": "packages/yt-api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run",
        "cwd": "packages/yt-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test",
        "cwd": "packages/yt-api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -- -D warnings",
        "cwd": "packages/yt-api"
      }
    }
  }
}
