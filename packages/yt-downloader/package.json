{
  "name": "yt-downloader",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    }
  },
  "bin": {
    "yt-downloader": "./cli.ts"
  },
  "scripts": {
    "download": "tsx cli.ts",
    "download:song": "tsx cli.ts --format mp3",
    "download:video": "tsx cli.ts --format mp4",
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "INTEGRATION=1 vitest run tests/integration/"
  },
  "dependencies": {
    "prompt-sync": "^4.2.0",
    "which": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompt-sync": "^4.2.3",
    "@types/which": "^3.0.4",
    "msw": "^2.13.4",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
