.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Docker files (avoid recursive context)
docker-compose.yml
.dockerignore

# Env files (secrets should not be baked in)
.env
.env.local

# Docs and misc
*.md
LICENSE
