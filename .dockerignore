# Version control
.git
.gitignore

# Node
node_modules
packages/*/node_modules

# Rust build artifacts
target
packages/yt-api/target

# Built outputs (rebuilt in Docker)
packages/yt-downloader/dist

# Frontend client (not needed for backend containers)
packages/yt-client

