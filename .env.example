# yt-api configuration
YT_API_HOST=0.0.0.0
YT_API_PORT=3000
GRPC_TARGET=http://yt-service:50051
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
STREAMING_TIMEOUT_SECS=600
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_BODY_SIZE_BYTES=1048576
RATE_LIMIT_RPM=30

# yt-service configuration
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
MAX_MESSAGE_SIZE=4194304

# yt-client configuration
VITE_API_BASE_URL=http://localhost:3000

# yt-downloader configuration
YT_DLP_AUDIO_QUALITY=0
YT_DLP_CUSTOM_ARGS=
YT_DLP_PROXY=
YT_DLP_COOKIES_FILE=
YT_DLP_SOCKET_TIMEOUT=30

# Directory where downloads are saved (inside the container)
DOWNLOAD_DIR=/home/appuser/Downloads/yt-downloader
