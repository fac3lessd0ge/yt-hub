# VM1 env (reverse proxy + yt-api)
COMPOSE_PROJECT_NAME=yt-hub-vm1
VERSION=latest
DOMAIN=example.com
LETSENCRYPT_EMAIL=ops@example.com

YT_API_HOST=0.0.0.0
YT_API_PORT=3000
GRPC_TARGET=http://10.0.2.15:50051
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
STREAMING_TIMEOUT_SECS=600
MAX_BODY_SIZE_BYTES=1048576
RATE_LIMIT_RPM=60
ALLOWED_ORIGINS=https://app.example.com

FILE_DELIVERY_MODE=remote
INTERNAL_FILE_BASE_URL=http://10.0.2.15:8081
INTERNAL_API_KEY=replace-with-strong-shared-secret
